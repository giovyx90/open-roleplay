{
  "oversized_in_gui": true,
  "hand_animation_on_swap": false,
  "model": {
    "type": "minecraft:range_dispatch",
    "property": "minecraft:custom_model_data",
    "entries": [
      {
        "threshold": 1,
        "model": {
          "type": "minecraft:condition",
          "property": "using_item",
          "on_true": {
            "type": "minecraft:model",
            "model": "custom/tools/crime/shield_blocking"
          },
          "on_false": {
            "type": "minecraft:model",
            "model": "custom/tools/crime/shield"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "using_item",
      "on_true": {
        "type": "minecraft:special",
        "base": "item/shield_blocking",
        "model": {
          "type": "shield"
        }
      },
      "on_false": {
        "type": "minecraft:special",
        "base": "item/shield",
        "model": {
          "type": "shield"
        }
      }
    },
    "index": 0
  }
}
